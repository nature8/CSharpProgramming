@model IEnumerable<MyMvcApp.Models.EmployeeModel>

@{
    ViewData["Title"] = "Employees";
}

<style>
    .employee-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

    .employee-table th,
    .employee-table td {
        padding: 12px 15px;
        text-align: left;
        border: none;
    }

    .employee-table th {
        font-weight: bold;
       
    }

    .action-links a {
        text-decoration: none;
        margin-right: 10px;
    }

    .action-links a:hover {
        text-decoration: underline;
    }
</style>

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

<table class="employee-table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.EName)</th>
            <th>@Html.DisplayNameFor(model => model.Job)</th>
            <th>@Html.DisplayNameFor(model => model.Salary)</th>
            <th>Actions</th>
        </tr>
    </thead>
    

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EName</td>
                <td>@item.Job</td>
                <td>@item.Salary</td>
                <td class="action-links">
                    <a asp-action="Edit"
                       asp-route-id="@item.EmployeeModelId">
                        Edit
                    </a>

                    <a asp-action="Details"
                       asp-route-id="@item.EmployeeModelId">
                        Details
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.EmployeeModelId">
                        Delete
                    </a>
                </td>
            </tr>
            
        }
    </tbody>
</table>